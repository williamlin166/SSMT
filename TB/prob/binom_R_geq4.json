{
  "vars": ["y_1", "y_2", "y_3"],
  "var_range": {
    "y_1": "0<=y_1<=1",
    "y_2": "0<=y_2<=2",
    "y_3": "0<=y_3<=4"
  },
  "var_dist": {
    "y_1": "Uniform(0,1)",
    "y_2": "Uniform(0,2)",
    "y_3": "Uniform(0,4)"
  },
  "condition": [
    "y_1 + y_2 + y_3 >= 4"
  ],
  "quant": ["r", "r", "r"],
  "ranges": [1, 2, 4]
}