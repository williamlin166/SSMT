{
  "vars": ["x", "y", "z"],
  "var_range": {
    "x": "0<=x<=1/2",
    "y": "0<=y<=1/2",
    "z": "-(x+y+1/2)<=z<=x+y+1/2"
  },
  "var_dist": {
    "z": "Uniform(-(x+y+1/2),x+y+1/2)"
  },
  "condition": [
    "80x - 20y + 10z + 50 >= 40"
  ],
  "quant": ["a", "e", "r"],
  "ranges": [null, null, "2x+2y+1"]
}