{
  "vars": ["x", "y", "z"],
  "var_range": {
    "x": "0<=x<=1/2",
    "y": "0<=y<=1/2",
    "z": "-(x+y+1/2)<=z<=x+y+1/2"
  },
  "var_dist": {
    "z": "Uniform(-(x+y+1/2),x+y+1/2)"
  },
  "condition": [
    "((x + y <= 1/2 && 40x - 40y + 10z + 100 >= 110) || (x + y > 1/2 && -80x - 160y + 10z + 160 >= 110))"
  ],
  "quant": ["e", "a", "r"],
  "ranges": [null, null, "2x+2y+1"]
}